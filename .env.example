# ══════════════════════════════════════════════════════════════════════════
# BOOTSTRAP VARIABLES — these 5 MUST be set in Railway/Render before deploy.
# Everything else (AI API keys, Turso, memory limits) is added LATER from
# your dashboard's Settings tab — no redeploy needed for those.
# ══════════════════════════════════════════════════════════════════════════

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram numeric user ID from @userinfobot
ADMIN_USER_ID=your_telegram_user_id_here

# Supabase project URL and anon key (Settings → API in Supabase dashboard)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Any password you choose — used to log into your dashboard
DASHBOARD_SECRET=choose_a_password_here

# ══════════════════════════════════════════════════════════════════════════
# OPTIONAL — you can ALSO set these here if you prefer env vars,
# but it's easier to add them later via Dashboard → Settings tab:
#   GROQ_API_KEY, GEMINI_API_KEY, OPENROUTER_API_KEY, COHERE_API_KEY,
#   TURSO_URL, TURSO_TOKEN, SUPABASE_MAX_MB,
#   MEMORY_WARN_PERCENT, MEMORY_URGENT_PERCENT
# ══════════════════════════════════════════════════════════════════════════
